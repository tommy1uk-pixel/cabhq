generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum BillingPlan {
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  DRIVER
}

enum DriverDocumentType {
  DRIVING_LICENCE
  DBS_CHECK
  TAXI_BADGE
  MEDICAL_CERTIFICATE
  RIGHT_TO_WORK
  INSURANCE
  OTHER
}

enum VehicleDocumentType {
  MOT_CERTIFICATE
  INSURANCE
  VEHICLE_INSPECTION
  VEHICLE_LICENCE
  LOG_BOOK
  SERVICE_RECORD
  TAX
  OTHER
}

enum ComplianceDocumentStatus {
  VALID
  EXPIRING
  EXPIRED
  NO_EXPIRY
}

model Company {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String
  code String? @unique
  slug String? @unique

  status CompanyStatus @default(PENDING)

  contactName  String?
  contactEmail String?
  contactPhone String?

  timezone String? @default("Europe/London")
  currency String? @default("GBP")

  driverLimit         Int @default(10)
  vehicleLimit        Int @default(10)
  dispatcherSeatLimit Int @default(3)

  billingPlan   BillingPlan   @default(STARTER)
  billingStatus BillingStatus @default(TRIAL)

  trialEndsAt          DateTime?
  subscriptionStartsAt DateTime?
  subscriptionEndsAt   DateTime?

  internalNotes String?

  bookings    Booking[]
  drivers     Driver[]
  shifts      DriverShift[]
  routePrices RoutePrice[]
  users       User[]
  vehicles    Vehicle[]
  settings    CompanySettings?
  invoices    Invoice[]
  payments    Payment[]
  accounts    Account[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(OPERATOR)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
}

model Driver {
  id             String    @id @default(uuid())
  name           String
  username       String?
  phone          String?
  email          String?
  pin            String
  status         String    @default("AVAILABLE")
  latitude       Float?
  longitude      Float?
  heading        Float?
  speed          Float?
  lastLocationAt DateTime?
  licenceNumber  String?
  badgeExpiry    DateTime?
  dbsExpiry      DateTime?
  licenceExpiry  DateTime?
  createdAt      DateTime  @default(now())
  companyId      String

  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  documents DriverDocument[]
  shifts    DriverShift[]
  vehicle   Vehicle?

  @@unique([companyId, username])
  @@index([companyId])
  @@index([status])
  @@index([name])
}

model DriverDocument {
  id                        String                   @id @default(uuid())
  driverId                  String
  documentType              DriverDocumentType
  title                     String
  fileName                  String
  filePath                  String
  mimeType                  String?
  fileSize                  Int?
  issueDate                 DateTime?
  expiryDate                DateTime?
  status                    ComplianceDocumentStatus @default(NO_EXPIRY)
  notes                     String?
  dbsUpdateServiceEnabled   Boolean                  @default(false)
  dbsUpdateServiceReference String?
  dbsUpdateServiceCheckedAt DateTime?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([status])
  @@index([expiryDate])
}

model Vehicle {
  id                   String    @id @default(uuid())
  reg                  String
  make                 String?
  model                String?
  colour               String?
  capacity             Int?      @default(4)
  status               String    @default("ACTIVE")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  companyId            String
  driverId             String?   @unique
  inspectionExpiry     DateTime?
  insuranceExpiry      DateTime?
  motExpiry            DateTime?
  notes                String?
  plateNumber          String?
  serviceDate          DateTime?
  taxExpiry            DateTime?
  vehicleLicenceExpiry DateTime?
  vin                  String?

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver    Driver?           @relation(fields: [driverId], references: [id], onDelete: SetNull)
  documents VehicleDocument[]

  @@index([companyId])
  @@index([status])
  @@index([reg])
}

model VehicleDocument {
  id           String                   @id @default(uuid())
  vehicleId    String
  documentType VehicleDocumentType
  title        String
  fileName     String
  filePath     String
  mimeType     String?
  fileSize     Int?
  issueDate    DateTime?
  expiryDate   DateTime?
  status       ComplianceDocumentStatus @default(NO_EXPIRY)
  notes        String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([status])
  @@index([expiryDate])
}

model Booking {
  id        String @id @default(uuid())
  reference String

  pickup     String
  dropoff    String
  pickupLat  Float?
  pickupLng  Float?
  dropoffLat Float?
  dropoffLng Float?

  customerName  String?
  customerPhone String?

  isThirdPartyBooking Boolean @default(false)

  bookerName  String?
  bookerPhone String?
  bookerEmail String?

  passengerName  String?
  passengerPhone String?
  passengerNotes String?

  passengerCount Int?
  notes          String?

  status     String
  pickupTime DateTime

  pricingMode     String?
  quotedPrice     Float?
  calculatedFare  Float?
  distanceMiles   Float?
  durationMinutes Float?

  isAirportBooking Boolean   @default(false)
  airportCode      String?
  airportName      String?
  airportTerminal  String?
  flightNumber     String?
  flightDirection  String?
  flightDateTime   DateTime?
  airline          String?
  meetAndGreet     Boolean   @default(false)
  airportNotes     String?

  createdAt DateTime @default(now())

  companyId String
  driverId  String?
  accountId String?

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver  Driver?        @relation(fields: [driverId], references: [id], onDelete: SetNull)
  account Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  events  BookingEvent[]

  @@index([companyId])
  @@index([driverId])
  @@index([accountId])
  @@index([status])
  @@index([pickupTime])
  @@index([bookerPhone])
  @@index([passengerPhone])
  @@index([isAirportBooking])
  @@index([airportCode])
  @@index([flightNumber])
}

model BookingEvent {
  id        String   @id @default(uuid())
  bookingId String
  message   String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
}

model RoutePrice {
  id         String   @id @default(uuid())
  fromLabel  String
  toLabel    String
  fixedPrice Float
  createdAt  DateTime @default(now())
  companyId  String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model DriverShift {
  id          String    @id @default(uuid())
  driverId    String
  companyId   String
  startedAt   DateTime
  endedAt     DateTime?
  startStatus String?
  endStatus   String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([companyId])
  @@index([startedAt])
  @@index([endedAt])
}

model CompanySettings {
  id        String @id @default(uuid())
  companyId String @unique

  dispatchAutoRefreshSeconds       Int     @default(10)
  driverTrackingIntervalSeconds    Int     @default(10)
  autoDispatchEnabled              Boolean @default(true)
  autoDispatchOfferTimeoutSeconds  Int     @default(20)
  allowManualDispatchOverride      Boolean @default(true)
  notifyDriversForNewJobs          Boolean @default(true)
  notifyOperatorsForCancelledJobs  Boolean @default(true)
  requireDriverPinLogin            Boolean @default(true)
  allowDriverShiftStartWithoutDocs Boolean @default(false)
  defaultTimezone                  String  @default("Europe/London")
  defaultCurrency                  String  @default("GBP")
  defaultCountry                   String  @default("United Kingdom")
  bookingsRequireQuotedPrice       Boolean @default(false)
  bookingsRequirePassengerCount    Boolean @default(true)
  showCompletedJobsOnDispatch      Boolean @default(true)
  completedJobsCompactMode         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Account {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId   String
  name        String
  code        String?
  email       String?
  phone       String?
  contactName String?

  address1 String?
  address2 String?
  city     String?
  postcode String?

  vatNumber    String?
  paymentTerms Int     @default(30)
  creditLimit  Float?  @default(0)

  status String  @default("ACTIVE")
  notes  String?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bookings Booking[]
  invoices Invoice[]
  payments Payment[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([name])
  @@index([status])
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String
  accountName   String
  status        String
  issueDate     DateTime
  dueDate       DateTime
  tripCount     Int      @default(0)
  subtotal      Float    @default(0)
  vat           Float    @default(0)
  total         Float    @default(0)
  paidAmount    Float    @default(0)
  balanceDue    Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  companyId     String
  accountId     String?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([accountId])
  @@index([status])
  @@index([issueDate])
  @@index([dueDate])
}

model Payment {
  id                String   @id @default(uuid())
  reference         String
  accountName       String
  method            String
  status            String
  amount            Float    @default(0)
  paymentDate       DateTime
  allocatedAmount   Float    @default(0)
  unallocatedAmount Float    @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  companyId         String
  invoiceId         String?
  accountId         String?

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([invoiceId])
  @@index([accountId])
  @@index([status])
  @@index([paymentDate])
}
