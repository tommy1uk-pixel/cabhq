generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id          String        @id @default(uuid())
  name        String
  createdAt   DateTime      @default(now())
  bookings    Booking[]
  drivers     Driver[]
  shifts      DriverShift[]
  routePrices RoutePrice[]
  users       User[]
  vehicles    Vehicle[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
}

model Driver {
  id             String           @id @default(uuid())
  name           String
  phone          String?
  email          String?
  pin            String
  status         String           @default("AVAILABLE")
  latitude       Float?
  longitude      Float?
  heading        Float?
  speed          Float?
  lastLocationAt DateTime?
  licenceNumber  String?
  badgeExpiry    DateTime?
  dbsExpiry      DateTime?
  licenceExpiry  DateTime?
  createdAt      DateTime         @default(now())
  companyId      String
  bookings       Booking[]
  company        Company          @relation(fields: [companyId], references: [id])
  documents      DriverDocument[]
  shifts         DriverShift[]
  vehicle        Vehicle?
}

model DriverDocument {
  id                        String                   @id @default(uuid())
  driverId                  String
  documentType              DriverDocumentType
  title                     String
  fileName                  String
  filePath                  String
  mimeType                  String?
  fileSize                  Int?
  issueDate                 DateTime?
  expiryDate                DateTime?
  status                    ComplianceDocumentStatus @default(NO_EXPIRY)
  notes                     String?
  dbsUpdateServiceEnabled   Boolean                  @default(false)
  dbsUpdateServiceReference String?
  dbsUpdateServiceCheckedAt DateTime?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  driver                    Driver                   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([status])
  @@index([expiryDate])
}

model Vehicle {
  id                   String            @id @default(uuid())
  reg                  String
  make                 String?
  model                String?
  colour               String?
  capacity             Int?              @default(4)
  status               String            @default("ACTIVE")
  createdAt            DateTime          @default(now())
  companyId            String
  driverId             String?           @unique
  inspectionExpiry     DateTime?
  insuranceExpiry      DateTime?
  motExpiry            DateTime?
  notes                String?
  plateNumber          String?
  serviceDate          DateTime?
  taxExpiry            DateTime?
  updatedAt            DateTime          @updatedAt
  vehicleLicenceExpiry DateTime?
  vin                  String?
  company              Company           @relation(fields: [companyId], references: [id])
  driver               Driver?           @relation(fields: [driverId], references: [id])
  documents            VehicleDocument[]

  @@index([companyId])
  @@index([status])
  @@index([reg])
}

model VehicleDocument {
  id           String                   @id @default(uuid())
  vehicleId    String
  documentType VehicleDocumentType
  title        String
  fileName     String
  filePath     String
  mimeType     String?
  fileSize     Int?
  issueDate    DateTime?
  expiryDate   DateTime?
  status       ComplianceDocumentStatus @default(NO_EXPIRY)
  notes        String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  vehicle      Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([status])
  @@index([expiryDate])
}

model Booking {
  id              String         @id @default(uuid())
  reference       String
  pickup          String
  dropoff         String
  pickupLat       Float?
  pickupLng       Float?
  dropoffLat      Float?
  dropoffLng      Float?
  status          String
  pickupTime      DateTime
  pricingMode     String?
  quotedPrice     Float?
  calculatedFare  Float?
  distanceMiles   Float?
  durationMinutes Float?
  createdAt       DateTime       @default(now())
  companyId       String
  driverId        String?
  company         Company        @relation(fields: [companyId], references: [id])
  driver          Driver?        @relation(fields: [driverId], references: [id])
  events          BookingEvent[]

  @@index([companyId])
  @@index([driverId])
  @@index([status])
  @@index([pickupTime])
}

model BookingEvent {
  id        String   @id @default(uuid())
  bookingId String
  message   String
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
}

model RoutePrice {
  id         String   @id @default(uuid())
  fromLabel  String
  toLabel    String
  fixedPrice Float
  createdAt  DateTime @default(now())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model DriverShift {
  id          String    @id @default(uuid())
  driverId    String
  companyId   String
  startedAt   DateTime
  endedAt     DateTime?
  startStatus String?
  endStatus   String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id])
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([companyId])
  @@index([startedAt])
  @@index([endedAt])
}

enum Role {
  ADMIN
  OPERATOR
  DRIVER
}

enum DriverDocumentType {
  DRIVING_LICENCE
  DBS_CHECK
  TAXI_BADGE
  MEDICAL_CERTIFICATE
  RIGHT_TO_WORK
  INSURANCE
  OTHER
}

enum VehicleDocumentType {
  MOT_CERTIFICATE
  INSURANCE
  VEHICLE_INSPECTION
  VEHICLE_LICENCE
  LOG_BOOK
  SERVICE_RECORD
  TAX
  OTHER
}

enum ComplianceDocumentStatus {
  VALID
  EXPIRING
  EXPIRED
  NO_EXPIRY
}
